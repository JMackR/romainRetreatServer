# Copy to `samconfig.toml` (recommended gitignored — see root .gitignore).
#   cp samconfig.toml.example samconfig.toml
#
# From `romainRetreatServer`:
#   yarn sam:build
#   sam deploy --guided
#   # later: sam deploy --config-env default

version = 0.1

[default.global.parameters]
stack_name = "romain-retreat-subgraph"

[default.build.parameters]
cached = true
parallel = true

[default.deploy.parameters]
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
resolve_s3 = true
region = "us-east-1"
# Required: DatabaseUrl and PayloadSecret have no template defaults. Empty overrides cause:
#   ValidationError: Parameters: [DatabaseUrl, PayloadSecret] must have values
# Edit the placeholders below (single line; space-separated Key=value). Use single quotes around values.
parameter_overrides = "DatabaseUrl='postgresql://postgres@YOUR_RDS_HOST.us-east-1.rds.amazonaws.com:5432/postgres?sslmode=require' PayloadSecret='REPLACE_WITH_LONG_RANDOM_SECRET'"
# IAM example (see docs/aws-federation-deploy.md). Attach VPC in Lambda console if RDS is private.
# parameter_overrides = "DatabaseUrl='postgresql://postgres@YOUR_RDS_HOST.us-east-1.rds.amazonaws.com:5432/postgres?sslmode=require' PayloadSecret='REPLACE_ME' UseRdsIamAuth=true RdsDbiResourceId=db-XXXXXXXX PayloadDatabasePush=1"

[default.package.parameters]
resolve_s3 = true
