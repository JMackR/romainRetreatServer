# Copy to `apollo.publish.env` (gitignored) and fill values.
#   cp apollo.publish.env.example apollo.publish.env
#
# Two publish flows live in this repo:
#
# 1. `yarn publish:aws-subgraphs` (RECOMMENDED for the AWS deploy)
#    - Publishes all 5 per-domain subgraphs (users / groups / search / content / system).
#    - For each domain, reads the Lambda Function URL from the CloudFormation stack output
#      `SubgraphUrl` of `romain-retreat-sg-<domain>`, then fetches the live `_service { sdl }`
#      from that URL and `rover subgraph publish`es it with the URL as `routing_url`.
#    - Only needs APOLLO_KEY + APOLLO_GRAPH_REF below; SUBGRAPH_NAME / SUBGRAPH_ROUTING_URL
#      / DATABASE_URL / PAYLOAD_SECRET are NOT used by this script (so leave them empty).
#    - Run after `yarn deploy:lambda all` (and after editing any code that affects the
#      pruned per-domain SDLs in subgraphs/_shared/subgraph/payloadSubgraphByDomain.ts or
#      subgraphs/_shared/federation/applyEntityModelToSubgraphSdl.ts).
#
# 2. `yarn publish:subgraph` (legacy, single `payload` monolith)
#    - Runs `yarn export:subgraph-sdl` locally (needs DATABASE_URL + PAYLOAD_SECRET so it
#      can boot Payload and dump the unified federated SDL).
#    - Publishes that one SDL as the `payload` subgraph using SUBGRAPH_ROUTING_URL.
#    - Useful when the supergraph is just one monolith service (local dev or pre-AWS topology).
#    - Don't mix with flow 1 — if a stale `payload` subgraph exists alongside the 5
#      per-domain ones, composition fails with INVALID_FIELD_SHARING (see
#      `rover subgraph delete <graph-ref> --name payload` to clean up).

# Required by both flows.
APOLLO_KEY=
APOLLO_GRAPH_REF=RomainRetreat@current

# --- Flow 2 (legacy `yarn publish:subgraph`) only -----------------------------
SUBGRAPH_NAME=payload
# SUBGRAPH_ROUTING_URL: Public URL where the monolith subgraph serves GraphQL.
#   - Leave empty or set to `auto` to use `supergraph/schema/aws.unified-file.yaml`
#     (subgraph: payload, routing_url).
#   - SUBGRAPH_USE_LOCALHOST_ROUTING=1 forces a 127.0.0.1 value through (local-only
#     supergraph in Studio).
# SUBGRAPH_ROUTING_URL=auto
# SUBGRAPH_ROUTING_URL=https://your-id.lambda-url.us-east-1.on.aws/graphql

# Required by `yarn export:subgraph-sdl` (which `yarn publish:subgraph` invokes):
# e.g. postgresql://... or local: postgresql://payload:payload@127.0.0.1:5432/payload
DATABASE_URL=
PAYLOAD_SECRET=
# Usually 0 for export; schema must already exist in the target DB.
PAYLOAD_DATABASE_PUSH=0
PAYLOAD_DISABLE_GRAPHQL=1
