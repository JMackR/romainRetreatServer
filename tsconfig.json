{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../romainRetreatCMS/src/*"],
      "@payload-config": ["../romainRetreatCMS/src/payload.config.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
