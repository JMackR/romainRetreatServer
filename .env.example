# Same secret as romainRetreatCMS (shared config).
PAYLOAD_SECRET=VYAZ4gzSpwMyycZI6NSNWjN9QoPfpazCfbDSGgcPRjQ=

# DATABASE_URL is read by `tsx`-launched subgraphs and the CMS, but is OVERRIDDEN inside
# `docker-compose.federation.yml` to point at the in-network Postgres 17 service (auto-seeded
# by `db-init`). So this value only matters when you run a subgraph directly on the host:
#   - Native dev (`yarn dev:subgraph:*`): use `yarn db:start` then this localhost URL.
#   - Docker stack (`yarn docker:federation:up`): IGNORED; postgres + schema + seed are baked in.
#   - AWS: RDS `postgresql://...?sslmode=require` (or IAM auth; see `template.yaml`).
DATABASE_URL=postgresql://payload:payload@127.0.0.1:5432/payload

# 1 on first boot of an empty DB (auto-runs Drizzle push). The Docker stack handles this for
# you via the one-shot `db-init` service; only set this manually for native `yarn dev`.
PAYLOAD_DATABASE_PUSH=1

# Public URL of this GraphQL server (playground + absolute links).
PAYLOAD_PUBLIC_SERVER_URL=http://127.0.0.1:3002

# Do not set PAYLOAD_DISABLE_GRAPHQL here; GraphQL must stay enabled on this process.

PORT=3002
