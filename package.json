{
  "name": "romain-retreat-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation tsx watch subgraphs/_shared/server.ts",
    "dev:subgraph:users": "cross-env NODE_OPTIONS=--no-deprecation tsx watch subgraphs/users/index.ts",
    "dev:subgraph:groups": "cross-env NODE_OPTIONS=--no-deprecation tsx watch subgraphs/groups/index.ts",
    "dev:subgraph:search": "cross-env NODE_OPTIONS=--no-deprecation tsx watch subgraphs/search/index.ts",
    "dev:subgraph:content": "cross-env NODE_OPTIONS=--no-deprecation tsx watch subgraphs/content/index.ts",
    "dev:subgraph:system": "cross-env NODE_OPTIONS=--no-deprecation tsx watch subgraphs/system/index.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation tsx subgraphs/_shared/server.ts",
    "db:start": "sh -c 'docker start romain-pg 2>/dev/null || docker run -d --name romain-pg -e POSTGRES_USER=payload -e POSTGRES_PASSWORD=payload -e POSTGRES_DB=payload -p 5432:5432 postgres:16-alpine'",
    "db:stop": "sh -c 'docker stop romain-pg 2>/dev/null || true'",
    "typecheck": "tsc --noEmit",
    "check:payload-version": "tsx scripts/verify-payload-version.mts",
    "compose:supergraph:local": "cross-env APOLLO_ELV2_LICENSE=accept sh -c 'rover supergraph compose --config supergraph/schema/local.yaml > supergraph/supergraph.local.graphql && cp supergraph/supergraph.local.graphql supergraph/supergraph.graphql'",
    "compose:supergraph": "yarn compose:supergraph:local",
    "compose:supergraph:docker": "cross-env APOLLO_ELV2_LICENSE=accept sh -c 'rover supergraph compose --config supergraph/schema/docker.yaml > supergraph/supergraph.docker.graphql'",
    "compose:supergraph:aws": "cross-env APOLLO_ELV2_LICENSE=accept sh -c 'rover supergraph compose --config supergraph/schema/aws.introspect.yaml > supergraph/supergraph.aws.graphql'",
    "compose:supergraph:aws:file": "cross-env APOLLO_ELV2_LICENSE=accept sh -c 'rover supergraph compose --config supergraph/schema/aws.unified-file.yaml > supergraph/supergraph.aws.graphql'",
    "compose:supergraph:unified": "cross-env APOLLO_ELV2_LICENSE=accept sh -c 'rover supergraph compose --config supergraph/schema/local.unified.yaml > supergraph/supergraph.local.graphql && cp supergraph/supergraph.local.graphql supergraph/supergraph.graphql'",
    "export:subgraph-sdl": "tsx scripts/export-subgraph-sdl.mts",
    "split:payload-sdl": "tsx scripts/split-payload-subgraph.mts",
    "export:subgraph:split": "yarn export:subgraph-sdl",
    "verify:domain-federation": "tsx scripts/verify-domain-federation.mts",
    "publish:subgraph": "tsx scripts/publish-subgraph.mts",
    "publish:subgraphs": "sh .scripts/publish.sh",
    "publish:subgraphs:docker": "sh .scripts/publish.sh docker-compose",
    "smoke": "sh .scripts/smoke.sh",
    "query": "sh .scripts/query.sh",
    "router:config:local": "sh .scripts/config.sh localhost > supergraph/schema/local.yaml",
    "router:config:docker": "sh .scripts/config.sh docker-compose > supergraph/schema/docker.yaml",
    "sam:build": "LAMBDA_BUILD_REPO_ROOT=\"$(pwd)\" sam build",
    "sam:deploy": "yarn sam:build && sam deploy",
    "deploy:lambda": "tsx scripts/deploy-lambda-sam.mts",
    "deploy:router": "tsx scripts/deploy-router.mts",
    "publish:aws-subgraphs": "tsx scripts/publish-aws-subgraphs.mts",
    "check:supergraph-parity": "tsx scripts/check-supergraph-parity.mts",
    "logs:router": "aws logs tail /ecs/romain-retreat-router --since 5m --follow --region us-east-1",
    "docker:federation:up": "sh scripts/federation-docker-up.sh",
    "docker:federation:down": "docker compose -f docker-compose.federation.yml down",
    "compose:supergraph:federation-docker": "docker compose -f docker-compose.federation.yml --profile tools run --rm supergraph-build"
  },
  "dependencies": {
    "@apollo/subgraph": "^2.9.0",
    "@aws-sdk/rds-signer": "^3.1041.0",
    "@graphql-tools/utils": "^11.0.1",
    "@hono/node-server": "^1.19.0",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "graphql-http": "^1.22.4",
    "hono": "^4.10.0",
    "next": "16.2.3",
    "payload": "3.84.1",
    "pg-connection-string": "2.6.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "esbuild": "^0.28.0",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
